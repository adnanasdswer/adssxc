@Composable
fun WebPageContent() {
    Column(modifier = Modifier.padding(16.dp)) {
        val annotatedLinkString: AnnotatedString = buildAnnotatedString {
            append("Go to Blog")
            addStyle(style = SpanStyle(color = Color.Blue, textDecoration = TextDecoration.Underline), start = 0, end = 9)
            addStringAnnotation(tag = "URL", annotation = "https://l.facebook.com/l.php?u=https%3A%2F%2Fnewnewnew23232.blogspot.com%2F2025%2F02%2Fhow-to-make-money-online-beginners", start = 0, end = 9)
        }
        
        ClickableText(
            text = annotatedLinkString,
            onClick = { offset ->
                annotatedLinkString.getStringAnnotations(tag = "URL", start = offset, end = offset)
                    .firstOrNull()?.let { annotation ->
                        val intent = Intent(Intent.ACTION_VIEW, Uri.parse(annotation.item))
                        startActivity(context, intent, null)
                    }
            }
        )

        Spacer(modifier = Modifier.height(16.dp))

        Text(text = "The internet has opened up countless opportunities for earning money online, making it possible for anyone with a computer or smartphone to generate income from home. Whether you're looking for a full-time job, a side hustle, or a way to monetize your skills, there are many ways to make money online.")

        Spacer(modifier = Modifier.height(8.dp))

        Text(text = "However, making money online is not an overnight success; it requires patience, consistency, and a strategic approach. Scams and get-rich-quick schemes are common pitfalls, so it’s essential to do thorough research and proceed with caution.")
    }
}

@Composable
fun ToggleClickAnimation() {
    val isClicked = remember { mutableStateOf(false) }
    
    LaunchedEffect(isClicked.value) {
        if (isClicked.value) {
            delay(10000)
            isClicked.value = false
        }
    }

    val context = LocalContext.current
    Column(modifier = Modifier.padding(16.dp)) {
        Button(onClick = { isClicked.value = true }) {
            Text("Click me")
        }

        if (isClicked.value) {
            Text("Button clicked!", color = Color.Red)
        }
    }
}
